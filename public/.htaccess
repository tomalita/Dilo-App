# index.html — never cache (ensures browser always loads the latest JS bundle)
<Files "index.html">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
</Files>

# JS/CSS assets have content-hash filenames — cache aggressively
<FilesMatch "\.(js|css|woff2|woff|ttf|svg|png|jpg|ico)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
